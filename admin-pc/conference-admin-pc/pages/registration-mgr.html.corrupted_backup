<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>鎶ュ悕姹囨€荤郴缁?- 鏅鸿兘浼氳绯荤粺</title>
    <link rel="stylesheet" href="../css/glassmorphism.css">
    <link rel="stylesheet" href="../css/conference-theme.css">
    <link rel="stylesheet" href="../css/components.css">
    <link rel="stylesheet" href="../css/browser-compatibility.css">
    <link rel="stylesheet" href="../css/interaction-enhancements.css">
    <link rel="stylesheet" href="../css/stat-cards-standard.css">
    <link rel="stylesheet" href="https://cdn.bootcdn.net/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <script src="https://cdn.bootcdn.net/ajax/libs/vue/3.3.4/vue.global.prod.js"></script>
    <script src="../js/interaction-utils.js"></script>
</head>
<body>
    <div id="app">
        <!-- 椤甸潰瀵艰埅鏍?-->
        <nav class="page-navigation">
            <div class="nav-content">
                <a href="../index.html" class="nav-back">
                    <i class="fas fa-arrow-left"></i>
                    <span>杩斿洖浼氳鍒楄〃</span>
                </a>
                <h1 class="nav-title">鎶ュ悕姹囨€荤郴缁?/h1>
                <div class="nav-actions"></div>
            </div>
        </nav>

        <!-- 涓诲唴瀹瑰尯鍩?-->
        <div class="page-with-nav" style="padding-top: 90px !important;">
        <!-- 椤甸潰澶撮儴 -->
        <div class="page-header glass-card">
            <div>
                <h2>鎶ュ悕姹囨€荤郴缁?/h2>
                <div class="conference-context">
                    <span class="context-label">褰撳墠浼氳:</span>
                    <span class="context-value">{{ conference.name }} ({{ conference.id }})</span>
                </div>
            </div>
            <div class="page-actions">
                <button class="btn-outline" @click="goToAudit">
                    <i class="fas fa-user-check"></i>
                    鏅鸿兘瀹℃牳
                </button>
                <button class="btn-primary" @click="goToSeating">
                    <i class="fas fa-chair"></i>
                    鏅鸿兘鎺掑骇
                </button>
                <button class="btn-outline" @click="goToRosterGeneration">
                    <i class="fas fa-file-export"></i>
                    鐢熸垚鍚嶅唽
                </button>
            </div>
        </div>

        <!-- 鎶ュ悕缁熻姒傝闈㈡澘 -->
        <div class="registration-stats-overview glass-card">
            <h3>鎶ュ悕缁熻姒傝</h3>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">{{ registrationStats.total }}</div>
                        <div class="stat-label">鎬绘姤鍚嶆暟</div>
                    </div>
                </div>
                <div class="stat-card success">
                    <div class="stat-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">{{ registrationStats.approved }}</div>
                        <div class="stat-label">宸插鏍告暟</div>
                    </div>
                </div>
                <div class="stat-card warning">
                    <div class="stat-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">{{ registrationStats.pending }}</div>
                        <div class="stat-label">鏈鏍告暟</div>
                    </div>
                </div>
                <div class="stat-card info" v-if="registrationStats.limitCount">
                    <div class="stat-icon">
                        <i class="fas fa-user-lock"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">{{ registrationStats.limitCount }}</div>
                        <div class="stat-label">闄愬畾鎶ュ悕浜烘暟</div>
                    </div>
                </div>
                <div class="stat-card danger" v-if="registrationStats.unregisteredUnits > 0">
                    <div class="stat-icon">
                        <i class="fas fa-building"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">{{ registrationStats.unregisteredUnits }}</div>
                        <div class="stat-label">鏈姤鍚嶅崟浣?/div>
                    </div>
                </div>
            </div>
            
            <!-- 鎶ュ悕瓒嬪娍鍥?-->
            <div class="trend-chart-section">
                <div class="chart-header">
                    <h4>鎶ュ悕瓒嬪娍鍥?/h4>
                    <div class="chart-controls">
                        <select v-model="trendTimeRange" @change="updateTrendChart">
                            <option value="today">浠婂ぉ</option>
                            <option value="week">鏈懆</option>
                            <option value="month">鏈湀</option>
                            <option value="custom">鑷畾涔?/option>
                        </select>
                    </div>
                </div>
                <div class="chart-container">
                    <div id="trendChart" style="width: 100%; height: 300px;"></div>
                </div>
            </div>
            
            <!-- 蹇€熸搷浣?-->
            <div class="quick-actions">
                <a href="reminder-urge.html" class="btn-warning btn-lg">
                    <i class="fas fa-bell"></i>
                    鍌姤鍌敹绯荤粺
                </a>
                <button class="btn-outline" @click="generateMockData">
                    <i class="fas fa-database"></i>
                    鐢熸垚铏氭嫙鏁版嵁
                </button>
                <button class="btn-outline" @click="exportStatsReport">
                    <i class="fas fa-file-download"></i>
                    瀵煎嚭缁熻鎶ュ憡
                </button>
            </div>
        </div>

        <!-- 澶氭笭閬撴姤鍚嶇鐞?-->
        <div class="channel-management glass-card">
            <h3>馃搳 澶氭笭閬撴姤鍚嶅垎鏋?/h3>
            <div class="channel-cards">
                <div v-for="channel in channels" :key="channel.type" 
                     class="channel-card" 
                     :class="{ active: selectedChannel === channel.type }"
                     @click="selectChannel(channel.type)">
                    <i :class="channel.icon"></i>
                    <span class="channel-name">{{ channel.name }}</span>
                    <div class="channel-stats">
                        <span class="stat-number">{{ channel.count }}</span>
                        <span class="stat-label">浜烘暟</span>
                    </div>
                    <div class="channel-trend" :class="channel.trend > 0 ? 'trend-up' : 'trend-down'">
                        {{ channel.trend > 0 ? '+' : '' }}{{ channel.trend }}%
                    </div>
                </div>
            </div>
        </div>

        <!-- 鎶ュ悕鏁版嵁琛ㄦ牸 - 鍙傝€冧細璁鐞嗕腑蹇冩牱寮?-->
        <div class="registration-data glass-card">
            <div class="section-header">
                <h3>馃搳 鎶ュ悕鏁版嵁鍒楄〃</h3>
                    <div class="header-actions">
                        <span class="data-count">鍏?{{ filteredRegistrations.length }} 鏉¤褰?/span>
                        <button class="btn-outline" @click="exportRegistrationData">
                            <i class="fas fa-download"></i>
                            瀵煎嚭鏁版嵁
                        </button>
                    </div>
            </div>
            
            <!-- 琛ㄦ牸宸ュ叿鏍?-->
            <div class="table-toolbar">
                <div class="toolbar-left">
                    <input type="text" 
                           v-model="searchQuery" 
                           @input="filterData"
                           placeholder="鎼滅储濮撳悕銆佸崟浣嶃€侀儴闂?.."
                           class="search-input">
                    <select v-model="statusFilter" @change="filterData" class="filter-select">
                        <option value="">鍏ㄩ儴鐘舵€?/option>
                        <option value="approved">宸查€氳繃</option>
                        <option value="pending">寰呭鏍?/option>
                        <option value="rejected">宸叉嫆缁?/option>
                    </select>
                    <select v-model="channelFilter" @change="filterData" class="filter-select">
                        <option value="">鍏ㄩ儴娓犻亾</option>
                        <option value="web">缃戦〉鎶ュ悕</option>
                        <option value="miniprogram">灏忕▼搴忔姤鍚?/option>
                        <option value="mobile">绉诲姩绔姤鍚?/option>
                    </select>
                </div>
                <div class="toolbar-right">
                    <template v-if="selectedRegistrations.length > 0">
                        <span class="batch-count">宸查€?{{ selectedRegistrations.length }} 浜?/span>
                        <button class="btn-sm btn-primary" @click="batchApproveSelected" v-if="hasPendingSelected">
                            <i class="fas fa-check"></i> 鎵归噺閫氳繃
                        </button>
                        <button class="btn-sm btn-outline" @click="clearSelectedRegistrations">
                            <i class="fas fa-times"></i> 娓呴櫎閫夋嫨
                        </button>
                    </template>
                    <template v-if="selectedRegistrations.length > 0 && groupingPreview.length > 0">
                        <select v-model="batchTargetGroup" class="batch-group-select">
                            <option value="">鍒嗛厤鍒扮粍</option>
                            <option v-for="group in groupingPreview" :key="group.id" :value="group.id">
                                {{ group.name }} ({{ group.memberCount }}浜?
                            </option>
                        </select>
                        <button class="btn-sm btn-primary" @click="batchAssignToGroup" :disabled="!batchTargetGroup">
                            <i class="fas fa-user-plus"></i> 鍒嗛厤
                        </button>
                    </template>
                </div>
            </div>
            
            <!-- 鎶ュ悕浜哄憳琛ㄦ牸 -->
            <div class="table-wrapper">
                <table class="registration-table">
                    <thead>
                        <tr>
                            <th width="40">
                                <input type="checkbox" v-model="selectAll" @change="toggleSelectAll">
                            </th>
                            <th>濮撳悕</th>
                            <th>鍗曚綅</th>
                            <th>閮ㄩ棬</th>
                            <th>鑱屽姟</th>
                            <th>鎶ュ悕娓犻亾</th>
                            <th>鎶ュ悕鏃堕棿</th>
                            <th>鏅鸿兘瀹℃牳</th>
                            <th>瀹℃牳鐘舵€?/th>
                            <th>鎿嶄綔</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="registration in paginatedRegistrations" :key="registration.id" :class="'status-row-' + registration.status">
                            <td>
                                <input type="checkbox" :checked="selectedRegistrations.includes(registration.id)" @change="toggleRegistration(registration.id)">
                            </td>
                            <td><strong>{{ registration.name }}</strong></td>
                            <td>{{ registration.unit }}</td>
                            <td>{{ registration.department }}</td>
                            <td>{{ registration.position }}</td>
                            <td>
                                <span class="channel-badge" :class="'channel-' + registration.channel">
                                    {{ getChannelText(registration.channel) }}
                                </span>
                            </td>
                            <td>{{ formatDate(registration.registeredAt) }}</td>
                            <td>
                                <span v-if="registration.ocrResult" class="badge" :class="'badge-' + getOCRStatusType(registration.ocrResult)">
                                    {{ getOCRStatusText(registration.ocrResult) }}
                                </span>
                                <span v-else class="badge badge-secondary">
                                    <i class="fas fa-minus-circle"></i> 鏈瘑鍒?                                </span>
                            </td>
                            <td>
                                <span class="badge" :class="'badge-review-' + registration.status">
                                    {{ getStatusText(registration.status) }}
                                </span>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <button v-if="registration.status === 'pending'" class="btn-xs btn-primary" @click="quickApprove(registration.id)">
                                        <i class="fas fa-check"></i> 閫氳繃
                                    </button>
                                    <button v-if="registration.status === 'pending'" class="btn-xs btn-danger" @click="quickReject(registration.id)">
                                        <i class="fas fa-times"></i> 鎷掔粷
                                    </button>
                                    <button class="btn-xs btn-outline" @click="viewDetails(registration.id)">
                                        <i class="fas fa-eye"></i> 璇︽儏
                                    </button>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <!-- 鍒嗛〉 -->
            <div class="table-pagination">
                <button class="btn-pagination btn-prev" :disabled="currentPage === 1" @click="prevPage" title="涓婁竴椤?>
                    <i class="fas fa-chevron-left"></i>
                    <span>涓婁竴椤?/span>
                </button>
                <div class="page-indicator">
                    <span class="page-text">绗?<strong>{{ currentPage }}</strong> / <strong>{{ totalPages }}</strong> 椤?鍏?<strong>{{ filteredRegistrations.length }}</strong> 鏉?/span>
                </div>
                <button class="btn-pagination btn-next" :disabled="currentPage >= totalPages" @click="nextPage" title="涓嬩竴椤?>
                    <span>涓嬩竴椤?/span>
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </div>

        <!-- 鏅鸿兘鍒嗙粍绠＄悊 -->
        <div class="smart-grouping glass-card">
            <div class="section-header">
                <h3>馃懃 鏅鸿兘鍒嗙粍绠＄悊</h3>
                <div class="header-actions">
                    <div class="grouping-toggle">
                        <span class="toggle-label">鍚敤鍒嗙粍:</span>
                        <button class="toggle-btn" :class="{ active: groupingEnabled }" @click="toggleGrouping">
                            <span class="toggle-slider"></span>
                            <span class="toggle-text">{{ groupingEnabled ? '宸插惎鐢? : '鏈惎鐢? }}</span>
                        </button>
                    </div>
                    <button class="btn-outline" @click="quickExportExcel" :disabled="!groupingEnabled">
                        <i class="fas fa-file-excel"></i>
                        瀵煎嚭Excel
                    </button>
                </div>
            </div>
            <div class="grouping-config" :class="{ disabled: !groupingEnabled }">
                <div class="config-item">
                    <label>鍒嗙粍渚濇嵁:</label>
                    <select v-model="groupingCriteria" @change="updateGroupingPreview">
                        <option value="department">鎸夐儴闂ㄥ垎缁?/option>
                        <option value="position">鎸夎亴绾у垎缁?/option>
                        <option value="expertise">鎸変笓涓氶鍩?/option>
                        <option value="mixed">娣峰悎鍒嗙粍</option>
                        <option value="random">闅忔満鍒嗙粍</option>
                    </select>
                </div>
                <div class="config-item">
                    <label>姣忕粍浜烘暟:</label>
                    <input type="number" v-model="groupSize" min="10" max="50" @change="updateGroupingPreview">
                </div>
                <div class="config-item">
                    <label>鍒嗙粍鏁伴噺:</label>
                    <input type="number" v-model="groupCount" min="1" max="20" readonly :disabled="!groupingEnabled">
                </div>
                <button class="btn-primary" @click="autoGrouping" :disabled="!groupingEnabled">
                    <i class="fas fa-users-cog"></i>
                    鎵ц鏅鸿兘鍒嗙粍
                </button>
            </div>
            <div class="grouping-preview" :class="{ disabled: !groupingEnabled }">
                <div v-if="groupingPreview.length === 0" class="empty-preview">
                    <p>璇峰厛閰嶇疆鍒嗙粍鍙傛暟骞舵墽琛屾櫤鑳藉垎缁?/p>
                </div>
                <div v-else>
                    <div class="preview-actions">
                        <button class="btn-sm btn-outline" @click="generateGroups">
                            <i class="fas fa-users"></i>
                            鑷姩鐢熸垚缇ょ粍
                        </button>
                    </div>
                    <table class="group-table">
                        <thead>
                            <tr>
                                <th>缁勫悕</th>
                                <th>浜烘暟</th>
                                <th>缁勯暱</th>
                                <th>鍒嗙粍渚濇嵁</th>
                                <th>鎿嶄綔</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr v-for="group in groupingPreview" :key="group.id">
                                <td>
                                    <input type="text" 
                                           v-model="group.name" 
                                           @blur="saveGroupName(group.id)"
                                           class="group-name-input">
                                </td>
                                <td>{{ group.memberCount }}浜?/td>
                                <td>
                                    <select v-model="group.leader" 
                                            @change="saveGroupLeader(group.id)"
                                            class="leader-select">
                                        <option value="">鏈寚瀹?/option>
                                        <option v-for="member in getGroupMembers(group.id)" 
                                                :key="member.id" 
                                                :value="member.name">
                                            {{ member.name }} ({{ member.unit }})
                                        </option>
                                    </select>
                                </td>
                                <td>{{ group.criteria }}</td>
                                <td>
                                    <button class="btn-sm btn-outline" @click="editGroupMembers(group.id)">
                                        <i class="fas fa-edit"></i>
                                        璋冩暣鎴愬憳
                                    </button>
                                    <button class="btn-sm btn-outline" @click="viewGroup(group.id)">
                                        <i class="fas fa-eye"></i>
                                        鏌ョ湅
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- 椤甸潰搴曢儴鎿嶄綔鍖?-->
        <div class="page-bottom-actions glass-card">
            <div class="bottom-actions-content">
                <div class="bottom-actions-info">
                    <i class="fas fa-info-circle"></i>
                    <span>瀹屾垚鎶ュ悕鏁版嵁瀹℃牳鍜屽垎缁勯厤缃悗锛岀偣鍑诲彸渚ф寜閽敓鎴愬弬浼氫汉鍛樺悕鍐?/span>
                </div>
                <button class="btn-primary btn-lg" @click="goToRosterGeneration">
                    <i class="fas fa-file-export"></i>
                    鐢熸垚鍙備細浜哄憳鍚嶅唽
                </button>
            </div>
        </div>
        </div><!-- 鍏抽棴page-with-nav -->

        <!-- 涓€閿偓鎶ュ脊绐?-->
        <div v-if="showReminderModal" class="modal-overlay" @click.self="showReminderModal = false">
            <div class="modal-content glass-card reminder-modal" @click.stop>
                <div class="modal-header">
                    <h3>鈴?涓€閿偓鎶?/h3>
                    <button class="btn-icon" @click="showReminderModal = false">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <!-- 姝ラ1: 閫夋嫨鍗曚綅 -->
                    <div class="reminder-step" v-if="reminderStep === 1">
                        <h4>姝ラ1: 閫夋嫨瑕佸偓鎶ョ殑鍗曚綅</h4>
                        <div class="unit-selection">
                            <div class="selection-actions">
                                <button class="btn-sm btn-outline" @click="selectAllUnits">
                                    {{ allUnitsSelected ? '鍙栨秷鍏ㄩ€? : '鍏ㄩ€? }}
                                </button>
                                <span class="selected-count">宸查€夋嫨 {{ selectedUnits.length }} 涓崟浣?/span>
                            </div>
                            <div class="unit-list">
                                <div v-for="unit in unregisteredUnits" :key="unit.id" 
                                     class="unit-item" 
                                     :class="{ selected: selectedUnits.includes(unit.id) }"
                                     @click="toggleUnit(unit.id)">
                                    <input type="checkbox" 
                                           :checked="selectedUnits.includes(unit.id)"
                                           @change.stop="toggleUnit(unit.id)">
                                    <div class="unit-info">
                                        <div class="unit-name">{{ unit.name }}</div>
                                        <div class="unit-meta">棰勮浜烘暟: {{ unit.expectedCount }}浜?/div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="step-actions">
                            <button class="btn-outline" @click="showReminderModal = false">鍙栨秷</button>
                            <button class="btn-primary" @click="reminderStep = 2" :disabled="selectedUnits.length === 0">
                                涓嬩竴姝ワ細閫夋嫨娓犻亾
                            </button>
                        </div>
                    </div>

                    <!-- 姝ラ2: 閫夋嫨娓犻亾 -->
                    <div class="reminder-step" v-if="reminderStep === 2">
                        <h4>姝ラ2: 閫夋嫨鍌姤娓犻亾</h4>
                        <div class="channel-selection">
                            <label class="channel-option" 
                                   v-for="channel in availableChannels" 
                                   :key="channel.value"
                                   :class="{ selected: reminderChannels.includes(channel.value) }">
                                <input type="checkbox" 
                                       :value="channel.value"
                                       v-model="reminderChannels">
                                <div class="channel-content">
                                    <i :class="channel.icon"></i>
                                    <div>
                                        <div class="channel-name">{{ channel.name }}</div>
                                        <div class="channel-desc">{{ channel.desc }}</div>
                                    </div>
                                </div>
                            </label>
                        </div>
                        <div class="step-actions">
                            <button class="btn-outline" @click="reminderStep = 1">涓婁竴姝?/button>
                            <button class="btn-primary" @click="reminderStep = 3" :disabled="reminderChannels.length === 0">
                                涓嬩竴姝ワ細閫夋嫨妯℃澘
                            </button>
                        </div>
                    </div>

                    <!-- 姝ラ3: 閫夋嫨妯℃澘 -->
                    <div class="reminder-step" v-if="reminderStep === 3">
                        <h4>姝ラ3: 閫夋嫨鍌姤妯℃澘</h4>
                        <div class="template-selection">
                            <select v-model="reminderTemplate" class="template-select">
                                <option value="gentle">娓╁拰鎻愰啋妯℃澘</option>
                                <option value="urgent">绱ф€ュ偓鎶ユā鏉?/option>
                                <option value="final">鏈€鍚庢満浼氭ā鏉?/option>
