                    const departments = ['缁煎悎绉?, '鍔炲叕瀹?, '浜轰簨绉?, '璐㈠姟绉?, '鏀跨瓥娉曡绉?, '涓氬姟涓€绉?, '涓氬姟浜岀', '鐩戠潱绉?];
                    const positions = ['澶勯暱', '鍓闀?, '绉戦暱', '鍓闀?, '涓讳换绉戝憳', '绉戝憳', '鍔炰簨鍛?];
                    const surnames = ['寮?, '鏉?, '鐜?, '璧?, '閽?, '瀛?, '鍛?, '鍚?, '閮?, '鍐?, '闄?, '瑜?, '鍗?, '钂?, '娌?, '闊?, '鏉?, '鏈?, '绉?, '灏?];
                    const names = ['浼?, '鑺?, '濞?, '鏁?, '闈?, '涓?, '寮?, '纾?, '鍐?, '娲?, '鍕?, '鑹?, '鏉?, '濞?, '娑?, '鏄?, '瓒?, '绉€鑻?, '鍗?, '骞?];
                    
                    const registrations = [];
                    for (let i = 1; i <= 100; i++) {
                        const surname = surnames[Math.floor(Math.random() * surnames.length)];
                        const name = names[Math.floor(Math.random() * names.length)];
                        const unit = units[Math.floor(Math.random() * units.length)];
                        const department = departments[Math.floor(Math.random() * departments.length)];
                        const position = positions[Math.floor(Math.random() * positions.length)];
                        // 80%閫氳繃锛?5%寰呭鏍革紝5%鎷掔粷
                        const rand = Math.random();
                        const status = rand < 0.80 ? 'approved' : (rand < 0.95 ? 'pending' : 'rejected');
                        
                        registrations.push({
                            id: i,
                            name: surname + name,
                            unit: unit,
                            department: department,
                            position: position,
                            phone: `138${String(Math.floor(Math.random() * 100000000)).padStart(8, '0')}`,
                            email: `user${i}@example.com`,
                            status: status,
                            channel: ['web', 'miniprogram', 'mobile'][Math.floor(Math.random() * 3)],
                            registeredAt: new Date(2024, 0, Math.floor(Math.random() * 30) + 1),
                            submitTime: new Date(2024, 0, Math.floor(Math.random() * 30) + 1),
                            auditTime: status !== 'pending' ? new Date(2024, 0, Math.floor(Math.random() * 30) + 1) : null,
                            reviewer: status !== 'pending' ? `瀹℃牳鍛?{String.fromCharCode(65 + Math.floor(Math.random() * 3))}` : null
                        });
                    }
                    return registrations;
                },
                
                async waitForConferenceContext() {
                    // 绛夊緟conferenceContext鍒濆鍖栧畬鎴?                    let retries = 0;
                    while (!window.conferenceContext && retries < 10) {
                        await new Promise(resolve => setTimeout(resolve, 100));
                        retries++;
                    }
                    // 濡傛灉conferenceContext宸插垵濮嬪寲锛岀瓑寰呭叾initialize瀹屾垚
                    if (window.conferenceContext && window.conferenceContext.initialize) {
                        try {
                            await window.conferenceContext.initialize();
                        } catch (error) {
                            console.warn('conferenceContext鍒濆鍖栬鍛?', error);
                        }
                    }
                },
                
                getConferenceId() {
                    const conferenceId = new URLSearchParams(window.location.search).get('conferenceId');
                    if (conferenceId) return conferenceId;
                    if (window.conferenceContext && window.conferenceContext.currentConference) {
                        return window.conferenceContext.currentConference.id;
                    }
                    return localStorage.getItem('currentConferenceId');
                },

                getApiHeaders() {
                    const headers = {
                        'Content-Type': 'application/json',
                        'X-Tenant-Id': localStorage.getItem('tenantId') || '2027317834622709762',
                        'X-User-Id': localStorage.getItem('userId') || '1'
                    };
                    const token = localStorage.getItem('authToken');
                    if (token) {
                        headers['Authorization'] = `Bearer ${token}`;
                    }
                    return headers;
                },

                mapStatusCode(statusCode) {
                    const map = {
                        0: 'pending',
                        1: 'approved',
                        2: 'rejected',
                        3: 'cancelled',
                        4: 'checkedin'
                    };
                    if (typeof statusCode === 'string') return statusCode;
                    return map[statusCode] || 'pending';
                },

                mapRegistrationFromApi(item) {
                    let registrationData = {};
                    try {
                        registrationData = item.registrationData ? JSON.parse(item.registrationData) : {};
                    } catch (e) {
                        registrationData = {};
                    }
                    const files = registrationData.files || {};
                    return {
                        id: item.id,
                        name: item.realName || item.name || '',
                        unit: item.department || item.organization || registrationData.unit || '',
                        department: item.department || item.organization || registrationData.department || '',
                        position: item.position || '',
                        phone: item.phone || '',
                        email: item.email || '',
