                            if (!positionMap[pos]) {
                                positionMap[pos] = [];
                            }
                            positionMap[pos].push(reg);
                        });
                        
                        const sortedPositions = Object.entries(positionMap)
                            .sort((a, b) => b[1].length - a[1].length);
                        
                        sortedPositions.forEach(([pos, members]) => {
                            members.forEach(member => {
                                let minGroup = groups[0];
                                groups.forEach(g => {
                                    if (g.members.length < minGroup.members.length) {
                                        minGroup = g;
                                    }
                                });
                                if (minGroup.members.length < groupSize) {
                                    minGroup.members.push(member);
                                }
                            });
                        });
                    } else if (this.groupingCriteria === 'random') {
                        // 闅忔満鍒嗙粍
                        const shuffled = [...registrations].sort(() => Math.random() - 0.5);
                        shuffled.forEach((member, idx) => {
                            const groupIdx = idx % groupCount;
                            if (groups[groupIdx].members.length < groupSize) {
                                groups[groupIdx].members.push(member);
                            }
                        });
                    } else {
                        // 娣峰悎鍒嗙粍锛堥粯璁わ級- 鎸夐『搴忓钩鍧囧垎閰?                        registrations.forEach((member, idx) => {
                            const groupIdx = Math.floor(idx / groupSize);
                            if (groupIdx < groupCount && groups[groupIdx].members.length < groupSize) {
                                groups[groupIdx].members.push(member);
                            }
                        });
                    }
                    
                    // 杩囨护鎺夌┖缁?                    return groups.filter(g => g.members.length > 0);
