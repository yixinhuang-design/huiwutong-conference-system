                        sortedDepts.forEach(([dept, members]) => {
                            members.forEach(member => {
                                // 鎵惧埌浜烘暟鏈€灏戠殑缁?                                let minGroup = groups[0];
                                groups.forEach(g => {
                                    if (g.members.length < minGroup.members.length) {
                                        minGroup = g;
                                    }
                                });
                                if (minGroup.members.length < groupSize) {
                                    minGroup.members.push(member);
                                }
                            });
                        });
                    } else if (this.groupingCriteria === 'position') {
                        // 鎸夎亴绾у垎缁?- 鍚岃亴绾у敖閲忓湪涓€缁?                        const positionMap = {};
                        registrations.forEach(reg => {
