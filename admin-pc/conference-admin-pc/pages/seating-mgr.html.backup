                        }
                    }
                },

                // ==================== 技术方案：辅助安排智能分配 ====================
                // 智能分配乘车
                async autoAssignTransport() {
                    this.$showLoading('正在智能分配乘车...');

                    const vehicles = this.transportList;
                    const attendeesWithoutTransport = this.attendees.filter(a => !a.transportAssigned);

                    if (attendeesWithoutTransport.length === 0) {
                        this.$hideLoading();
                        this.$showToast('所有人员已分配车辆', 'info');
                        return;
                    }

                    // 按部门分组分配到同一车辆
                    const deptGroups = this.groupAttendeesByDepartment(attendeesWithoutTransport);

                    for (const vehicle of vehicles) {
                        const remainingCapacity = vehicle.capacity - vehicle.assignedCount;
                        if (remainingCapacity <= 0) continue;

                        // 优先分配同部门人员
                        for (const dept in deptGroups) {
                            if (deptGroups[dept].length === 0) continue;

                            const assignCount = Math.min(remainingCapacity, deptGroups[dept].length);
                            const assigned = deptGroups[dept].splice(0, assignCount);

                            assigned.forEach(attendee => {
                                this.assignAttendeeToVehicle(attendee, vehicle);
                            });

                            vehicle.assignedCount += assignCount;
                            if (vehicle.assignedCount >= vehicle.capacity) break;
                        }
                    }

                    this.$hideLoading();
                    this.$showToast('乘车分配完成', 'success');
                },

                // 智能分配住宿
                async autoAssignAccommodation() {
                    this.$showLoading('正在智能分配住宿...');

                    const rooms = this.accommodationList;
                    const attendeesWithoutRoom = this.attendees.filter(a => !a.roomAssigned);

                    if (attendeesWithoutRoom.length === 0) {
                        this.$hideLoading();
                        this.$showToast('所有人员已分配房间', 'info');
                        return;
                    }

                    // 考虑性别和部门因素
                    const maleAttendees = attendeesWithoutRoom.filter(a => a.gender === '男' && !a.roomAssigned);
                    const femaleAttendees = attendeesWithoutRoom.filter(a => a.gender === '女' && !a.roomAssigned);

                    for (const room of rooms) {
                        const remainingCapacity = room.capacity - room.assignedCount;
                        if (remainingCapacity <= 0) continue;

                        let assigned = [];

                        if (room.type === '单人间') {
                            // 单人间随机分配
                            const candidates = [...maleAttendees, ...femaleAttendees].filter(a => !a.roomAssigned);
                            if (candidates.length > 0) {
                                assigned = [candidates[0]];
                            }
                        } else {
                            // 双人间尽量同性别
                            let candidates;
                            if (remainingCapacity >= 2) {
                                if (maleAttendees.filter(a => !a.roomAssigned).length >= 2) {
                                    candidates = maleAttendees.filter(a => !a.roomAssigned).slice(0, 2);
                                } else if (femaleAttendees.filter(a => !a.roomAssigned).length >= 2) {
                                    candidates = femaleAttendees.filter(a => !a.roomAssigned).slice(0, 2);
                                } else {
                                    // 混合分配
                                    const available = [...maleAttendees, ...femaleAttendees].filter(a => !a.roomAssigned);
                                    candidates = available.slice(0, remainingCapacity);
                                }
                            } else {
                                const available = [...maleAttendees, ...femaleAttendees].filter(a => !a.roomAssigned);
                                candidates = available.slice(0, 1);
                            }

                            assigned = candidates || [];
                        }

                        assigned.forEach(attendee => {
                            this.assignAttendeeToRoom(attendee, room);
                            attendee.roomAssigned = true;
                        });

                        room.assignedCount += assigned.length;
                    }

                    this.$hideLoading();
                    this.$showToast('住宿分配完成', 'success');
                },

                // 智能分配讨论室
                async autoAssignDiscussions() {
                    this.$showLoading('正在智能分配讨论室...');

                    const rooms = this.discussionList;
                    const attendeesWithoutDiscussion = this.attendees.filter(a => !a.discussionAssigned);

                    if (attendeesWithoutDiscussion.length === 0) {
                        this.$hideLoading();
                        this.$showToast('所有人员已分配讨论室', 'info');
                        return;
                    }

                    // 按部门分组，每个部门分配到不同讨论室
                    const deptGroups = this.groupAttendeesByDepartment(attendeesWithoutDiscussion);

                    for (const room of rooms) {
                        const remainingCapacity = room.capacity - room.assignedCount;
                        if (remainingCapacity <= 0) continue;

                        // 分配一个完整的部门到讨论室
                        for (const dept in deptGroups) {
                            if (deptGroups[dept].length === 0) continue;

                            const assignCount = Math.min(remainingCapacity, deptGroups[dept].length);
                            const assigned = deptGroups[dept].splice(0, assignCount);

                            assigned.forEach(attendee => {
                                this.assignAttendeeToDiscussion(attendee, room);
                                attendee.discussionAssigned = true;
                            });

                            room.assignedCount += assignCount;
                            break;
                        }
                    }

                    this.$hideLoading();
                    this.$showToast('讨论室分配完成', 'success');
                },

                // 按部门分组参会人员
                groupAttendeesByDepartment(attendees) {
                    const groups = {};
                    attendees.forEach(attendee => {
                        if (!groups[attendee.department]) {
                            groups[attendee.department] = [];
                        }
                        groups[attendee.department].push(attendee);
                    });
                    return groups;
                },

                // 分配参会者到车辆
                assignAttendeeToVehicle(attendee, vehicle) {
                    if (!vehicle.passengers) {
                        vehicle.passengers = [];
                    }
                    vehicle.passengers.push({
                        id: attendee.id,
                        name: attendee.name,
                        department: attendee.department
                    });
                    attendee.transportAssigned = true;
                    attendee.vehicleId = vehicle.id;
                },

                // 分配参会者到房间
                assignAttendeeToRoom(attendee, room) {
                    if (!room.occupants) {
                        room.occupants = [];
                    }
                    room.occupants.push({
                        id: attendee.id,
                        name: attendee.name,
                        gender: attendee.gender
                    });
                    attendee.roomAssigned = true;
                    attendee.roomId = room.id;
                },

                // 分配参会者到讨论室
                assignAttendeeToDiscussion(attendee, disc) {
                    if (!disc.groups) {
                        disc.groups = [];
                    }
                    const existingGroup = disc.groups.find(g => g.department === attendee.department);
                    if (existingGroup) {
                        existingGroup.members.push({
                            id: attendee.id,
                            name: attendee.name
                        });
                    } else {
                        disc.groups.push({
                            department: attendee.department,
                            members: [{ id: attendee.id, name: attendee.name }]
                        });
                    }
                    attendee.discussionAssigned = true;
                    attendee.discussionId = disc.id;
                },

                // 座位调整相关方法
                openAdjustmentPanel() {
                    this.$showToast('打开座位调整面板', 'info');
                },

                viewAdjustmentHistory() {
                    this.$showToast('查看变更历史', 'info');
                },

                // 导出和分享相关方法
                async exportSeatingExcel() {
                    this.$showToast('导出Excel座位表功能', 'info');
                },

                async exportSeatingPDF() {
                    this.$showToast('导出PDF座位表功能', 'info');
                },

                async generateCheckInQR() {
                    // ==================== 技术方案：生成查座二维码 ====================
                    try {
                        this.$showLoading('正在生成查座二维码...');

                        // 生成查座页面URL
                        const baseUrl = window.location.origin;
                        const checkInUrl = `${baseUrl}/pages/check-seat.html?conf=${this.conference.id}`;

                        // 生成二维码数据
                        const qrData = {
                            conferenceId: this.conference.id,
                            type: 'seating_check',
                            timestamp: Date.now(),
                            url: checkInUrl
                        };

                        // 在实际应用中，这里应该使用二维码生成库
                        // 例如：qrcode.js 或 QRCode.js
                        // const qrCode = await QRCode.toDataURL(checkInUrl);

                        // 模拟生成过程
                        await new Promise(resolve => setTimeout(resolve, 1000));

                        // 更新分享链接
                        this.shareLink = checkInUrl;

                        this.$hideLoading();
                        this.$showToast('查座二维码已生成', 'success');

                        // 在实际应用中，可以显示二维码图片
                        // document.getElementById('qrCodeImage').src = qrCode;
                    } catch (error) {
                        this.$hideLoading();
                        this.$showToast('生成失败', 'error');
                    }
                },

                copyShareLink() {
                    navigator.clipboard.writeText(this.shareLink);
                    this.$showToast('链接已复制到剪贴板', 'success');
                },

                resolveConflict(conflictId) {
                    this.$showToast(`解决冲突: ${conflictId}`, 'info');
                },

                // 更新排座方式界面状态
                updateSeatingMethodUI() {
                    // 根据排座方式更新界面
                    switch(this.seatingMethod) {
                        case 'excel':
                            console.log('Excel导入模式：请上传Excel文件');
                            break;
                        case 'rule':
                            console.log('规则排座模式：请配置排座规则');
                            break;
                        case 'zone':
                            console.log('区域排座模式：请选择区域进行排座');
                            break;
                    }
                },

                // 更新算法配置
                updateAlgorithmConfig() {
                    // 根据选择的算法更新配置
                    switch(this.selectedAlgorithm) {
                        case 'smart':
                            console.log('智能推荐算法：综合考虑多种因素');
                            break;
                        case 'department':
                            console.log('部门优先算法：按部门集中排座');
                            break;
                        case 'position':
                            console.log('职位优先算法：按职位等级排座');
                            break;
                        case 'random':
                            console.log('随机排座算法：随机分配座位');
                            break;
                    }
                },

                goBack() {
                    window.history.back();
                },

                // ==================== 功能1: 座位图可视化编辑器 ====================

                // 缩放控制
                zoomIn() {
                    this.viewScale = Math.min(this.viewScale + 0.1, 2);
                    this.saveToHistory('zoom');
                },

                zoomOut() {
                    this.viewScale = Math.max(this.viewScale - 0.1, 0.5);
                    this.saveToHistory('zoom');
                },

                resetView() {
                    this.viewScale = 1;
                    this.viewOffsetX = 0;
                    this.viewOffsetY = 0;
                    this.saveToHistory('resetView');
                },

                // 平移控制
                panLeft() {
                    this.viewOffsetX += 50;
                    this.saveToHistory('pan');
                },

                panRight() {
                    this.viewOffsetX -= 50;
                    this.saveToHistory('pan');
                },

                panUp() {
                    this.viewOffsetY += 50;
                    this.saveToHistory('pan');
                },

                panDown() {
                    this.viewOffsetY -= 50;
                    this.saveToHistory('pan');
                },

                // 撤销/重做
                saveToHistory(action) {
                    // 如果当前不在历史记录末尾，删除后面的记录
                    if (this.historyIndex < this.historyStack.length - 1) {
                        this.historyStack = this.historyStack.slice(0, this.historyIndex + 1);
                    }

                    // 保存当前状态
                    const state = {
                        action: action,
                        seatingAreas: JSON.parse(JSON.stringify(this.seatingAreas)),
                        attendees: JSON.parse(JSON.stringify(this.attendees)),
                        viewScale: this.viewScale,
                        viewOffsetX: this.viewOffsetX,
                        viewOffsetY: this.viewOffsetY,
                        timestamp: Date.now()
                    };

                    this.historyStack.push(state);

                    // 限制历史记录大小
                    if (this.historyStack.length > this.maxHistorySize) {
                        this.historyStack.shift();
                    } else {
                        this.historyIndex++;
                    }

                    this.updateUndoRedoState();
                },

                undo() {
                    if (this.canUndo && this.historyIndex > 0) {
                        this.historyIndex--;
                        this.restoreHistoryState(this.historyStack[this.historyIndex]);
                    }
                },

                redo() {
                    if (this.canRedo && this.historyIndex < this.historyStack.length - 1) {
                        this.historyIndex++;
                        this.restoreHistoryState(this.historyStack[this.historyIndex]);
                    }
                },

                restoreHistoryState(state) {
                    this.seatingAreas = JSON.parse(JSON.stringify(state.seatingAreas));
                    this.attendees = JSON.parse(JSON.stringify(state.attendees));
                    this.viewScale = state.viewScale;
                    this.viewOffsetX = state.viewOffsetX;
                    this.viewOffsetY = state.viewOffsetY;
                    this.updateUndoRedoState();
                    this.updateStatistics();
                },

                updateUndoRedoState() {
                    this.canUndo = this.historyIndex > 0;
                    this.canRedo = this.historyIndex < this.historyStack.length - 1;
                },

                // 座位选择
                selectSeat(seat, event) {
                    // Ctrl+点击：多选
                    if (event.ctrlKey || event.metaKey) {
                        const index = this.selectedSeats.findIndex(s => s.id === seat.id);
                        if (index > -1) {
                            this.selectedSeats.splice(index, 1);
                        } else {
                            this.selectedSeats.push(seat);
                        }
                    }
                    // Shift+点击：范围选择
                    else if (event.shiftKey && this.selectedSeats.length > 0) {
                        const lastSeat = this.selectedSeats[this.selectedSeats.length - 1];
                        this.selectSeatRange(lastSeat, seat);
                    }
                    // 单击：单选
                    else {
                        this.selectedSeats = [seat];
                    }
                },

                selectSeatRange(startSeat, endSeat) {
                    // 简化实现：选择两座位之间的所有座位
                    const startArea = this.seatingAreas.find(a => a.id === startSeat.areaId);
                    const endArea = this.seatingAreas.find(a => a.id === endSeat.areaId);

                    if (!startArea || !endArea || startArea.id !== endArea.id) {
                        return; // 跨区域暂不支持
                    }

                    const startRow = startArea.rows.find(r => r.number === startSeat.row);
                    const endRow = startArea.rows.find(r => r.number === endSeat.row);

                    if (!startRow || !endRow) return;

                    // 选择范围内所有座位
                    const minRow = Math.min(startSeat.row, endSeat.row);
                    const maxRow = Math.max(startSeat.row, endSeat.row);

                    startArea.rows.forEach(row => {
                        if (row.number >= minRow && row.number <= maxRow) {
                            row.seats.forEach(seat => {
                                if (!seat.isAisle) {
                                    if (!this.selectedSeats.find(s => s.id === seat.id)) {
                                        this.selectedSeats.push(seat);
                                    }
                                }
                            });
                        }
                    });
                },

                selectAllSeats() {
                    this.selectedSeats = [];
                    this.seatingAreas?.forEach(area => {
                        area?.rows?.forEach(row => {
                            row?.seats?.forEach(seat => {
                                if (!seat?.isAisle) {
                                    this.selectedSeats.push(seat);
                                }
                            });
                        });
                    });
                    this.$showToast(`已选择 ${this.selectedSeats.length} 个座位`, 'info');
                },

                clearSelection() {
                    this.selectedSeats = [];
                },

                // 拖拽功能
                startDrag(seat, event) {
                    if (!this.manualAdjustMode) return;
                    this.isDragging = true;
                    this.dragStartSeat = seat;
                    event.preventDefault();
                },

                onDrag(event) {
                    if (!this.isDragging) return;
                    // 拖拽逻辑可在这里实现
                },

                endDrag(event) {
                    if (!this.isDragging) return;
                    this.isDragging = false;
                    this.dragStartSeat = null;
                    this.saveToHistory('drag');
                },

                // ==================== 功能2: 导示图生成 ====================

                async generateGuideMap() {
                    this.$showLoading('正在生成导示图...');

                    try {
                        // 创建临时canvas
                        const canvas = document.createElement('canvas');
                        const ctx = canvas.getContext('2d');

                        // 设置画布大小
                        canvas.width = this.guideImageConfig.width;
                        canvas.height = this.guideImageConfig.height;

                        // 绘制背景
                        ctx.fillStyle = this.guideImageConfig.backgroundColor;
                        ctx.fillRect(0, 0, canvas.width, canvas.height);

                        // 计算缩放比例
                        const padding = 100;
                        const availableWidth = canvas.width - padding * 2;
                        const availableHeight = canvas.height - padding * 2;

                        // 绘制主席台
                        ctx.fillStyle = '#FFD700';
                        ctx.fillRect(padding, padding, availableWidth, 60);
                        ctx.fillStyle = '#000';
                        ctx.font = 'bold 32px Arial';
                        ctx.textAlign = 'center';
                        ctx.fillText('主席台 / 讲台', canvas.width / 2, padding + 40);

                        // 绘制座位区
                        let startY = padding + 100;

                        for (const area of this.seatingAreas) {
                            // 绘制区域名称
                            ctx.fillStyle = area.type === 'vip' ? '#FF69B4' : '#667EEA';
                            ctx.font = 'bold 24px Arial';
                            ctx.textAlign = 'left';
                            ctx.fillText(area.name, padding, startY);

                            startY += 40;

                            // 计算每个座位的大小
                            const maxCols = Math.max(...area.rows.map(r => r.seats.filter(s => !s.isAisle).length));
                            const seatWidth = Math.min(40, availableWidth / maxCols);
                            const seatHeight = 30;
                            const rowGap = 10;

                            // 绘制每一排
                            for (const row of area.rows) {
                                let startX = padding;

                                for (const seat of row.seats) {
                                    if (seat.isAisle) {
                                        startX += seatWidth / 2; // 过道占半个座位宽度
                                        continue;
                                    }

                                    // 绘制座位
                                    if (seat.occupant) {
                                        if (seat.occupant.isVip) {
                                            ctx.fillStyle = '#FF69B4'; // VIP - 粉色
                                        } else {
                                            ctx.fillStyle = '#667EEA'; // 普通参会者 - 紫色
                                        }
                                    } else if (seat.isReserved) {
                                        ctx.fillStyle = '#FBC2EB'; // 预留 - 浅紫色
                                    } else {
                                        ctx.fillStyle = 'rgba(255, 255, 255, 0.3)'; // 空座位
                                    }

                                    ctx.fillRect(startX, startY, seatWidth - 4, seatHeight);

                                    // 绘制座位号
                                    if (this.guideImageConfig.showLabels) {
                                        ctx.fillStyle = '#FFF';
                                        ctx.font = '12px Arial';
                                        ctx.textAlign = 'center';
                                        ctx.fillText(seat.number, startX + seatWidth / 2 - 2, startY + seatHeight / 2 + 4);
                                    }

                                    startX += seatWidth;
                                }

                                startY += seatHeight + rowGap;
                            }

                            startY += 30;
                        }

                        // 绘制图例
                        if (this.guideImageConfig.showLegend) {
                            const legendY = canvas.height - 120;
                            const legendX = padding;
                            const legendItemWidth = 150;

                            ctx.font = '16px Arial';
                            ctx.textAlign = 'left';

                            // 图例项
                            const legends = [
                                { color: '#667EEA', label: '已分配座位' },
                                { color: '#FF69B4', label: 'VIP座位' },
                                { color: '#FBC2EB', label: '预留座位' },
                                { color: 'rgba(255, 255, 255, 0.3)', label: '空座位' }
                            ];

                            legends.forEach((legend, index) => {
                                ctx.fillStyle = legend.color;
                                ctx.fillRect(legendX + index * legendItemWidth, legendY, 20, 20);
                                ctx.fillStyle = '#FFF';
                                ctx.fillText(legend.label, legendX + index * legendItemWidth + 30, legendY + 15);
                            });
                        }

                        // 导出图片
                        const dataUrl = canvas.toDataURL(`image/${this.guideImageConfig.format}`, 0.9);

                        // 创建下载链接
                        const link = document.createElement('a');
                        link.download = `座位导示图_${this.conference.name}_${Date.now()}.${this.guideImageConfig.format}`;
                        link.href = dataUrl;
                        link.click();

                        this.$hideLoading();
                        this.$showToast('导示图已生成（高清PNG格式）', 'success');

                        // 在实际应用中，可以显示二维码
                        // document.getElementById('guideMapImage').src = dataUrl;
                    } catch (error) {
                        console.error('生成导示图失败:', error);
                        this.$hideLoading();
                        this.$showToast('生成导示图失败', 'error');
                    }
                },

                // ==================== 功能3: 手动调整功能 ====================

                toggleManualAdjustMode() {
                    this.manualAdjustMode = !this.manualAdjustMode;
                    this.$showToast(
                        this.manualAdjustMode ? '已进入手动调整模式' : '已退出手动调整模式',
                        'info'
                    );
                },

                // 批量操作
                bulkAssignAttendee() {
                    if (this.selectedSeats.length === 0) {
                        this.$showToast('请先选择座位', 'warning');
                        return;
                    }

                    // 简化实现：弹出选择参会人员的对话框
                    // 实际应用中应该显示参会人员列表供选择
                    this.$showToast(`请选择要分配到 ${this.selectedSeats.length} 个座位的参会人员`, 'info');
                },

                bulkClearSeats() {
                    if (this.selectedSeats.length === 0) {
                        this.$showToast('请先选择座位', 'warning');
                        return;
                    }

                    if (confirm(`确定要清空 ${this.selectedSeats.length} 个座位吗？`)) {
                        this.selectedSeats.forEach(seat => {
                            seat.occupant = null;
                            seat.isReserved = false;
                        });

                        this.saveToHistory('bulkClear');
                        this.clearSelection();
                        this.updateStatistics();
                        this.$showToast('座位已清空', 'success');
                    }
                },

                bulkReserveSeats() {
                    if (this.selectedSeats.length === 0) {
                        this.$showToast('请先选择座位', 'warning');
                        return;
                    }

                    this.selectedSeats.forEach(seat => {
                        if (!seat.occupant) {
                            seat.isReserved = true;
                        }
                    });

                    this.saveToHistory('bulkReserve');
                    this.$showToast(`${this.selectedSeats.length} 个座位已设为预留`, 'success');
                },

                bulkLockSeats() {
                    if (this.selectedSeats.length === 0) {
                        this.$showToast('请先选择座位', 'warning');
                        return;
                    }

                    this.selectedSeats.forEach(seat => {
                        seat.isLocked = !seat.isLocked;
                    });

                    this.saveToHistory('bulkLock');
                    this.$showToast('座位锁定状态已更新', 'success');
                },

                // 填充剩余座位
                fillRemainingSeats() {
                    const unassignedAttendees = this.attendees?.filter(a => !a.assignedSeat) || [];
                    const emptySeats = [];

                    // 收集所有空座位
                    this.seatingAreas?.forEach(area => {
                        area?.rows?.forEach(row => {
                            row?.seats?.forEach(seat => {
                                if (!seat?.occupant && !seat.isAisle && !seat.isReserved && !seat.isLocked) {
                                    emptySeats.push(seat);
                                }
                            });
                        });
                    });

                    if (unassignedAttendees.length === 0) {
                        this.$showToast('所有参会人员已分配座位', 'info');
                        return;
                    }

                    if (emptySeats.length === 0) {
                        this.$showToast('没有可用座位', 'warning');
                        return;
                    }

                    const assignCount = Math.min(unassignedAttendees.length, emptySeats.length);

                    for (let i = 0; i < assignCount; i++) {
                        const attendee = unassignedAttendees[i];
                        const seat = emptySeats[i];

                        seat.occupant = attendee;
                        attendee.assignedSeat = seat.id;
                    }

                    this.saveToHistory('fillRemaining');
                    this.updateStatistics();
                    this.$showToast(`已分配 ${assignCount} 个座位`, 'success');
                },

                // 交换座位
                swapSeats(seat1, seat2) {
                    if (!seat1.occupant || !seat2.occupant) {
                        this.$showToast('两个座位都必须已分配才能交换', 'warning');
                        return;
                    }

                    const temp = seat1.occupant;
                    seat1.occupant = seat2.occupant;
                    seat2.occupant = temp;

                    // 更新参会人员的座位信息
                    seat1.occupant.assignedSeat = seat1.id;
                    seat2.occupant.assignedSeat = seat2.id;

                    this.saveToHistory('swap');
                    this.$showToast('座位已交换', 'success');
                }
            },
            watch: {
                // 监听座位区域变化，自动更新统计数据
                seatingAreas: {
                    handler() {
                        this.updateStatistics();
                    },
                    deep: true
                },
                // 监听排座方式变化
                seatingMethod(newVal) {
                    console.log('排座方式已切换到:', newVal);
                    // 切换排座方式时更新界面状态
                    this.updateSeatingMethodUI();
                },
                // 监听算法选择变化
                selectedAlgorithm(newVal) {
                    console.log('算法已切换到:', this.getAlgorithmName(newVal));
                    // 算法变化时更新相关配置
                    this.updateAlgorithmConfig();
                },
                // 监听规则配置变化
                rules: {
                    handler() {
                        console.log('排座规则已更新');
                        // 规则变化时标记需要重新应用
                        this.rulesNeedReapply = true;
                    },
                    deep: true
                },
                // 监听冲突列表变化
                conflicts: {
                    handler(newVal) {
                        if (newVal.length > 0) {
                            console.log('检测到', newVal.length, '个座位冲突');
                        }
                    },
                    deep: true
                }
            },
            mixins: [window.InteractionMixin]
        });

        // 配置全局错误处理器
        app.config.errorHandler = (err, vm, info) => {
            console.error('========== Vue 错误 ==========');
            console.error('错误信息:', err.message);
            console.error('组件信息:', info);
            // 返回 true 让错误继续传播，这样可以看到原始错误
            return true;
        };

        app.mount('#app');
    </script>

    <style>
        /* ==================== 座位区配置弹窗样式 ==================== */
        .area-config-modal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            backdrop-filter: blur(5px);
        }

        .modal-content {
            background: white;
            border-radius: var(--radius-xl);
            width: 90%;
            max-width: 700px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            pointer-events: auto;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: var(--space-5);
            border-bottom: 1px solid var(--gray-200);
            position: relative;
            z-index: 1;
            pointer-events: auto;
        }

        .modal-header h3 {
            font-size: var(--font-size-xl);
            font-weight: 600;
            color: var(--gray-900);
            margin: 0;
        }

        .close-btn {
            width: 36px;
            height: 36px;
            border: none;
            background: transparent;
            font-size: var(--font-size-xl);
            color: var(--gray-600);
            cursor: pointer;
            border-radius: var(--radius-md);
            transition: all var(--transition-fast);
            position: relative;
            z-index: 10000;
            pointer-events: auto !important;
        }

        .close-btn:hover {
            background: var(--gray-100);
            color: var(--gray-900);
        }

        .modal-body {
            padding: var(--space-5);
        }

        .modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: var(--space-3);
            padding: var(--space-5);
            border-top: 1px solid var(--gray-200);
        }

        .config-group {
            margin-bottom: var(--space-4);
        }

        .config-group label {
            display: block;
            font-size: var(--font-size-sm);
            font-weight: 500;
            color: var(--gray-700);
            margin-bottom: var(--space-2);
        }

        .config-group input[type="text"],
        .config-group input[type="number"],
        .config-group select {
            width: 100%;
            padding: var(--space-2) var(--space-3);
            border: 1px solid var(--gray-300);
            border-radius: var(--radius-md);
            font-size: var(--font-size-base);
            transition: all var(--transition-fast);
        }

        .config-group input:focus,
        .config-group select:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .config-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-4);
        }

        .config-section-title {
            display: flex;
            align-items: center;
            gap: var(--space-2);
            font-size: var(--font-size-base);
            font-weight: 600;
            color: var(--gray-900);
            margin: var(--space-5) 0 var(--space-3);
            padding-bottom: var(--space-2);
            border-bottom: 2px solid var(--primary-color);
        }

        .number-input {
            display: flex;
            align-items: center;
            border: 1px solid var(--gray-300);
            border-radius: var(--radius-md);
            overflow: hidden;
        }

        .number-input button {
            width: 40px;
            height: 40px;
            border: none;
            background: var(--gray-100);
            font-size: var(--font-size-lg);
            cursor: pointer;
            transition: all var(--transition-fast);
        }

        .number-input button:hover {
            background: var(--gray-200);
        }

        .number-input input {
            flex: 1;
            border: none;
            text-align: center;
            font-size: var(--font-size-base);
            font-weight: 600;
        }

        .number-input input:focus {
            outline: none;
        }

        .angle-control {
            margin-bottom: var(--space-3);
        }

        .angle-slider {
            width: 100%;
            height: 6px;
            margin-bottom: var(--space-3);
        }

        .angle-presets {
            display: flex;
            gap: var(--space-2);
        }

        .angle-presets button {
            flex: 1;
            padding: var(--space-2) var(--space-3);
            border: 1px solid var(--gray-300);
            background: white;
            border-radius: var(--radius-md);
            cursor: pointer;
            transition: all var(--transition-fast);
            font-size: var(--font-size-sm);
        }

        .angle-presets button:hover {
            background: var(--gray-100);
        }

        .angle-presets button.active {
            background: var(--primary-color);
            color: white;
            border-color: var(--primary-color);
        }

        .angle-preview {
            display: flex;
            justify-content: center;
            padding: var(--space-4);
            background: var(--gray-50);
            border-radius: var(--radius-md);
        }

        .preview-box {
            width: 60px;
            height: 60px;
            border: 2px dashed var(--primary-color);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: var(--font-size-xs);
            color: var(--primary-color);
            transition: transform 0.3s ease;
        }

        .checkbox-label {
            display: flex;
            align-items: center;
            gap: var(--space-2);
            cursor: pointer;
            font-size: var(--font-size-sm);
            color: var(--gray-700);
        }

        .checkbox-label input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .aisle-config,
        .fixed-seats-config {
            margin-top: var(--space-3);
            padding-left: var(--space-6);
        }

        .aisle-config label,
        .fixed-seats-config label {
            display: block;
            font-size: var(--font-size-xs);
            color: var(--gray-600);
            margin-bottom: var(--space-1);
        }

        .aisle-config select,
        .aisle-config input,
        .fixed-seats-config input {
            width: 100%;
        }

        .fixed-seats-input small {
            display: block;
            margin-top: var(--space-1);
            color: var(--gray-500);
            font-size: var(--font-size-xs);
        }

        .preview-container {
            margin-top: var(--space-4);
            padding: var(--space-4);
            background: var(--gray-50);
            border-radius: var(--radius-md);
            overflow-x: auto;
        }

        .preview-area {
            display: inline-block;
            padding: var(--space-4);
            background: white;
            border-radius: var(--radius-md);
            border: 2px solid var(--gray-200);
            transition: transform 0.3s ease;
            min-width: 300px;
        }

        .preview-label {
            text-align: center;
            font-weight: 600;
            margin-bottom: var(--space-3);
            color: var(--gray-900);
        }

        .preview-row {
            display: flex;
            align-items: center;
            margin-bottom: var(--space-2);
        }

        .preview-row-label {
            width: 50px;
            font-size: var(--font-size-xs);
            color: var(--gray-600);
            text-align: right;
            margin-right: var(--space-2);
        }

        .preview-seats {
            display: flex;
            gap: var(--space-1);
        }

        .preview-seat {
            width: 30px;
            height: 30px;
            border: 1px solid var(--gray-400);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            background: white;
            color: var(--gray-700);
        }

        .preview-seat.vip {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
            border-color: transparent;
        }

        .preview-seat.aisle {
            background: var(--gray-300);
            border-color: var(--gray-400);
            color: var(--gray-500);
        }

        .preview-seat.fixed {
            background: rgba(255, 193, 7, 0.2);
            border-color: #ffc107;
            border-width: 2px;
        }

        .config-stats {
            display: flex;
            gap: var(--space-4);
            margin-top: var(--space-4);
            padding: var(--space-3);
            background: rgba(102, 126, 234, 0.05);
            border-radius: var(--radius-md);
        }

        .config-stats .stat-item {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .config-stats .stat-label {
            font-size: var(--font-size-xs);
            color: var(--gray-600);
        }

        .config-stats .stat-value {
            font-size: var(--font-size-lg);
            font-weight: 700;
            color: var(--primary-color);
        }

        /* 响应式 */
        @media (max-width: 768px) {
            .modal-content {
                width: 95%;
            }

            .config-row {
                grid-template-columns: 1fr;
            }

            .angle-presets {
                flex-wrap: wrap;
            }

            .angle-presets button {
                min-width: calc(25% - var(--space-2));
            }
        }
    </style>
</body>
</html>
