                async executeSeating() {
                    const confirmed = await this.$showConfirm(
                        '确定要执行排座吗？这将重新分配所有座位。',
                        '执行排座',
                        'warning'
                    );
                    if (confirmed) {
                        try {
                            this.$showLoading('正在执行排座...');

                            // 根据选择的排座方式执行不同的逻辑
                            if (this.seatingMethod === 'excel') {
                                // Excel导入方式 - 模拟导入
                                await this.executeExcelSeating();
                            } else if (this.seatingMethod === 'rule') {
                                // 按规则排座
                                await this.executeRuleSeating();
                            } else if (this.seatingMethod === 'zone') {
                                // 按分区排座
                                await this.executeZoneSeating();
                            }

                            this.$hideLoading();
                            this.$showToast('排座完成', 'success');
                            this.updateStatistics(); // 更新统计数据
                        } catch (error) {
                            this.$hideLoading();
                            this.$showToast('排座失败: ' + error.message, 'error');
                        }
                    }
                },

