                // 导入参会人员
                async importAttendees() {
                    // 创建一个文件输入元素
                    const input = document.createElement('input');
                    input.type = 'file';
                    input.accept = '.xlsx,.xls,.csv';

                    input.onchange = async (e) => {
                        const file = e.target.files[0];
                        if (file) {
                            this.$showLoading('正在导入参会人员...');

                            // 模拟导入过程（实际应该使用Excel解析库）
                            await new Promise(resolve => setTimeout(resolve, 1000));

                            // 这里应该解析Excel文件并提取参会人员数据
                            // 暂时使用模拟数据
                            this.attendees = this.generateMockAttendees();

                            this.$hideLoading();
                            this.$showToast(`成功导入 ${this.attendees.length} 名参会人员`, 'success');
                            this.updateStatistics();
                        }
                    };

                    input.click();
                },

                // 手动添加参会人员
                addAttendeeManual() {
                    const name = prompt('请输入参会者姓名:');
                    if (!name || !name.trim()) return;

                    const department = prompt('请输入部门:', '其他');
                    const position = prompt('请输入职位:', '参会人员');

                    const isVip = confirm('是否为VIP嘉宾？');

                    const newAttendee = {
                        id: `att_${Date.now()}`,
                        name: name.trim(),
                        department: department || '其他',
                        position: position || '参会人员',
                        isVip: isVip,
                        gender: '男',
                        specialNeeds: [],
                        hasRegistered: true
                    };

                    this.attendees.push(newAttendee);
                    this.$showToast(`已添加参会人员: ${newAttendee.name}`, 'success');
                    this.updateStatistics();
                },

                // 清空参会人员
                async clearAttendees() {
                    if (this.attendees.length === 0) {
                        this.$showToast('参会人员列表已经是空的', 'info');
                        return;
                    }

                    const confirmed = await this.$showConfirm(
                        `确定要清空所有参会人员吗？当前有 ${this.attendees.length} 名参会人员。`,
                        '清空参会人员',
                        'warning'
                    );

                    if (confirmed) {
                        this.attendees = [];
                        this.clearAllSeats();
                        this.$showToast('已清空所有参会人员', 'success');
                        this.updateStatistics();
                    }
                },

                generateRows(areaPrefix, rowCount, seatsPerRow) {
                    const rows = [];
                    for (let i = 1; i <= rowCount; i++) {
                        const seats = [];
                        for (let j = 1; j <= seatsPerRow; j++) {
                            seats.push({
                                id: `${areaPrefix}${i}_${j}`,
                                area: areaPrefix,
                                row: i,
                                col: j,  // 添加col属性
                                number: j,
                                type: 'regular',
                                status: 'available',
                                occupant: null
                            });
                        }
                        rows.push({
                            number: i,
                            seats: seats
                        });
                    }
                    return rows;
                },

                // ==================== 技术方案：座位区生成算法 ====================
                // 生成座位布局（支持角度旋转）
                generateSeatingLayout(config) {
                    const { areaId, rows, cols, angle, type } = config;
                    const seats = [];

                    for (let r = 1; r <= rows; r++) {
                        for (let c = 1; c <= cols; c++) {
                            const seat = {
                                id: `${areaId}${r}_${c}`,
                                area: areaId,
                                row: r,
                                col: c,
                                number: c,
                                x: this.calculateX(r, c, angle || 0),
                                y: this.calculateY(r, c, angle || 0),
                                status: 'available',
                                type: this.determineSeatType(r, c, config)
                            };
                            seats.push(seat);
                        }
                    }

                    // 按行组织座位
                    const layout = [];
                    for (let r = 1; r <= rows; r++) {
                        layout.push({
                            number: r,
                            seats: seats.filter(s => s.row === r),
                            hasAisle: false  // 初始化为false，后续applyAisleToRows会更新
                        });
                    }

                    return layout;
                },

                // X坐标计算（用于角度旋转）
                calculateX(row, col, angle) {
                    const radian = (angle * Math.PI) / 180;
                    return col * Math.cos(radian) - row * Math.sin(radian);
                },

                // Y坐标计算（用于角度旋转）
                calculateY(row, col, angle) {
                    const radian = (angle * Math.PI) / 180;
                    return col * Math.sin(radian) + row * Math.cos(radian);
                },

                // 确定座位类型
                determineSeatType(row, col, config) {
                    if (config.type === 'vip') {
                        return 'vip';
                    }
                    // 可以添加更多逻辑，比如前排固定座位等
                    return 'regular';
                },

                // 获取座位区样式（支持角度等配置）
                getAreaStyle(area) {
                    const style = {};

                    // 应用角度旋转
                    if (area.angle && area.angle !== 0) {
                        style.transform = `rotate(${area.angle}deg)`;
                        style.transformOrigin = 'center center';
                    }

                    return style;
                },

                // 计算座位区在会场中的位置（模拟真实布局）
                getAreaPositionStyle(area, index) {
                    // 根据座位区索引计算位置
                    const positions = [
                        { top: '20px', left: '50%', transform: 'translateX(-50%)' },  // 第1个区：前排居中
                        { top: '20px', right: '20px' },  // 第2个区：右侧
                        { top: '20px', left: '20px' }   // 第3个区：左侧
                    ];

                    // 如果座位区超过3个，使用网格布局
                    if (index >= positions.length) {
                        const cols = 3;
                        const row = Math.floor(index / cols);
                        const col = index % cols;
                        return {
                            top: `${20 + row * 220}px`,
                            left: `${50 + (col - 1) * 33}%`,
                            transform: col === 1 ? 'translateX(-50%)' : 'none'
                        };
                    }

                    return positions[index] || {};
                },

                // 获取行的样式（用于过道处理）
                getRowStyle(row, area) {
                    const style = {};

                    // 安全检查
                    if (!row || !area) {
                        return style;
                    }

                    // 如果该行有过道，添加左边距
                    if (row.hasAisle && area.aislePosition === 'left') {
                        style.marginLeft = `${area.aisleWidth * 47}px`;
                    }

                    return style;
                },

                // 获取单个座位样式
                getSeatStyle(seat, area) {
                    const style = {};

                    // 安全检查
                    if (!seat) {
                        return style;
                    }

                    // 如果是过道座位，使用特殊样式
                    if (seat.isAisle) {
                        style.background = 'rgba(128, 128, 128, 0.2)';
                        style.border = '2px dashed rgba(128, 128, 128, 0.4)';
                        style.cursor = 'not-allowed';
                        style.opacity = '0.5';
                        return style;
                    }

                    // 如果座位已被占用，样式在getSeatClass中处理
                    if (seat.occupant) {
                        return style;
                    }

                    // 如果座位被预留
                    if (seat.isReserved) {
                        style.background = 'linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%)';
                        return style;
                    }

                    // 如果是固定座位
                    if (seat.isFixed) {
                        style.border = '2px solid #FFD700';
                        style.background = 'rgba(255, 215, 0, 0.1)';
                        return style;
                    }

                    // VIP区域的空座位使用粉色背景
                    if (area.type === 'vip') {
                        style.background = 'linear-gradient(135deg, rgba(240, 147, 251, 0.3) 0%, rgba(245, 87, 108, 0.3) 100%)';
                        style.border = '1px solid rgba(240, 147, 251, 0.5)';
                    }

                    return style;
                },

                simulateAssignedSeats() {
                    // 模拟已分配的座位
                    let assigned = 0;
                    const targetAssigned = 356;
                    let vipCount = 0;

                    this.seatingAreas?.forEach(area => {
                        area?.rows?.forEach(row => {
                            row?.seats?.forEach(seat => {
                                if (assigned < targetAssigned && Math.random() > 0.3) {
                                    // VIP区域优先分配VIP座位
                                    if (area?.id === 'area_a' && vipCount < 45) {
                                        seat.type = 'vip';
                                        seat.status = 'occupied';
                                        vipCount++;
                                    } else if (area?.id !== 'area_a') {
                                        seat.status = 'occupied';
                                    } else {
                                        return; // 跳过未分配的座位
                                    }

                                    seat.occupant = {
                                        name: `学员${assigned + 1}`,
                                        department: ['技术部', '产品部', '市场部', '销售部'][Math.floor(Math.random() * 4)]
                                    };
                                    assigned++;
                                }
                            });
                        });
                    });

                    // 更新统计数据
                    this.statistics.assigned = assigned;
                    this.statistics.available = this.statistics.totalSeats - assigned;
                    this.statistics.vip = vipCount;

                    console.log(`座位分配完成: 已分配${assigned}个座位, VIP${vipCount}个`);
                },
                
                selectAlgorithm(algoId) {
                    this.selectedAlgorithm = algoId;
                },

                getSeatClass(seat) {
                    // 安全检查
                    if (!seat || !seat.id) {
                        return '';
                    }

                    const classes = [seat.status || 'available'];

                    // 检查是否在选中列表中
                    if (this.selectedSeats.find(s => s.id === seat.id)) {
                        classes.push('selected');
                    }

                    if (seat.type === 'vip') {
                        classes.push('vip');
                    }

                    if (seat.isAisle) {
                        classes.push('aisle');
                    }

                    if (seat.isReserved) {
                        classes.push('reserved');
                    }

                    if (seat.isLocked) {
                        classes.push('locked');
                    }

                    return classes.join(' ');
                },

                handleSeatClick(seat, event) {
                    // 手动调整模式：使用新的选择系统
                    if (this.manualAdjustMode) {
                        this.selectSeat(seat, event);
                        return;
                    }

                    // 原有的编辑模式逻辑
                    if (this.editMode === 'assign') {
                        if (seat.status === 'available') {
                            // 打开分配对话框
                            this.assignSeat(seat);
                        } else {
                            this.selectedSeat = seat;
                        }
                    } else if (this.editMode === 'swap') {
                        if (!this.selectedSeat) {
                            this.selectedSeat = seat;
                        } else {
                            this.swapSeats(this.selectedSeat, seat);
                            this.selectedSeat = null;
                        }
                    } else if (this.editMode === 'vip') {
                        seat.type = seat.type === 'vip' ? 'regular' : 'vip';
                    }
                },
                
                async assignSeat(seat) {
                    // 显示分配对话框（实际应该使用模态框）
                    const name = prompt('请输入参会者姓名:');
                    if (name && name.trim()) {
                        seat.status = 'occupied';
                        seat.occupant = {
                            name: name.trim(),
                            department: '待定'
                        };
                        this.statistics.assigned++;
                        this.statistics.available--;
                        if (this.$showToast) {
                            this.$showToast('座位分配成功', 'success');
                        } else if (window.InteractionUtils) {
                            window.InteractionUtils.showToast('座位分配成功', 'success');
                        }
                    }
                },

                getAreaOccupied(areaId) {
                    const area = this.seatingAreas?.find(a => a?.id === areaId);
                    if (!area?.rows) return 0;

                    let count = 0;
                    area.rows.forEach(row => {
                        row?.seats?.forEach(seat => {
                            if (seat?.status === 'occupied') count++;
                        });
                    });
                    return count;
                },

                getAreaCols(areaId) {
                    const area = this.seatingAreas?.find(a => a?.id === areaId);
                    if (!area?.rows || area.rows.length === 0) return 0;

                    // 返回第一行的座位数（假设每行座位数相同）
                    return area.rows[0]?.seats?.length || 0;
                },

                getAreaCapacity(areaId) {
                    const area = this.seatingAreas?.find(a => a?.id === areaId);
                    if (!area?.rows) return 0;

                    return area.rows.reduce((sum, row) => {
                        return sum + (row?.seats?.length || 0);
                    }, 0);
                },
                
                async autoArrange() {
                    // 验证是否有参会人员
                    if (!this.attendees || this.attendees.length === 0) {
                        this.$showToast('没有参会人员数据，请先导入参会人员', 'warning');
                        return;
                    }

                    // 验证座位数量
                    const totalSeats = this.getTotalSeatsCount();
                    if (totalSeats < this.attendees.length) {
                        const confirmed = await this.$showConfirm(
                            `座位数量不足！需要${this.attendees.length}个座位，但只有${totalSeats}个。是否继续？`,
                            '座位数量不足',
                            'warning'
                        );
                        if (!confirmed) return;
                    }

                    const confirmed = await this.$showConfirm(
                        `确定要执行自动排座吗？将为${this.attendees.length}名参会人员分配座位。`,
                        '自动排座',
                        'warning'
                    );
                    if (confirmed) {
                        try {
                            this.$showLoading(`正在执行${this.getAlgorithmName(this.selectedAlgorithm)}...`);

                            // 先清空所有座位
                            this.clearAllSeats();

                            // 根据选择的算法执行排座
                            if (this.selectedAlgorithm === 'smart') {
                                await this.executeSmartAlgorithm();
                            } else if (this.selectedAlgorithm === 'department') {
                                await this.executeDepartmentAlgorithm();
                            } else if (this.selectedAlgorithm === 'position') {
                                await this.executePositionAlgorithm();
                            } else if (this.selectedAlgorithm === 'random') {
                                await this.executeRandomAlgorithm();
                            }

                            // 应用排座规则
                            this.applySeatingRules();

                            // 检测冲突
                            this.detectConflicts();

                            this.seatingCompleted = true;
                            this.$hideLoading();
                            this.$showToast(`${this.getAlgorithmName(this.selectedAlgorithm)}排座完成`, 'success');
                            this.updateStatistics();

                            // 保存到历史记录
                            this.saveToHistory('autoArrange');
                        } catch (error) {
                            this.$hideLoading();
                            this.$showToast('排座失败: ' + error.message, 'error');
                        }
                    }
                },

                // 获取总座位数
                getTotalSeatsCount() {
                    return this.seatingAreas?.reduce((total, area) => {
                        return total + (area?.rows?.reduce((rowTotal, row) => {
                            return rowTotal + (row?.seats?.length || 0);
                        }, 0) || 0);
                    }, 0) || 0;
                },

                // 获取所有可用座位（按区域排序）
                getAllAvailableSeats() {
                    const seats = [];
                    this.seatingAreas?.forEach(area => {
                        area?.rows?.forEach(row => {
                            row?.seats?.forEach(seat => {
                                if (seat?.status === 'available') {
                                    seats.push({ ...seat, areaId: area.id, areaType: area.type });
                                }
                            });
                        });
                    });
                    return seats;
                },

                // 为参会人员分配座位
                assignAttendeeToSeat(attendee, seat) {
                    // 在实际座位数据中找到并更新
                    this.seatingAreas?.forEach(area => {
                        area?.rows?.forEach(row => {
                            const foundSeat = row?.seats?.find(s => s?.id === seat?.id);
                            if (foundSeat) {
                                foundSeat.status = 'occupied';
                                foundSeat.occupant = {
                                    id: attendee.id,
                                    name: attendee.name,
                                    department: attendee.department,
                                    position: attendee.position,
                                    gender: attendee.gender
                                };
                                if (attendee.isVip) {
                                    foundSeat.type = 'vip';
                                }
                            }
                        });
                    });
                },

                // 清空所有座位
                clearAllSeats() {
                    this.seatingAreas?.forEach(area => {
                        area?.rows?.forEach(row => {
                            row?.seats?.forEach(seat => {
                                seat.status = 'available';
                                seat.occupant = null;
                                seat.type = 'regular';
                            });
                        });
                    });
                    this.seatingCompleted = false;
                    this.conflicts = [];
                },

                // ==================== 排座算法实现 ====================
                // 智能推荐算法：综合考虑多个因素
                async executeSmartAlgorithm() {
                    console.log('执行智能推荐算法...');

                    // 1. 首先安排VIP人员（前排居中）
                    const vipAttendees = this.getVipAttendees();
                    await this.assignVipSeats(vipAttendees);

                    // 2. 安排有特殊需求的人员
                    const specialNeedsAttendees = this.getSpecialNeedsAttendees().filter(a => !a.isVip);
                    await this.assignSpecialNeedsSeats(specialNeedsAttendees);

                    // 3. 按部门安排剩余人员（部门内部按职级排序）
                    const remainingAttendees = this.attendees.filter(a =>
                        !a.isVip && (!a.specialNeeds || a.specialNeeds.length === 0)
                    );
                    await this.assignByDepartmentWithPosition(remainingAttendees);

                    console.log('智能推荐算法执行完成');
                },

                // 按部门排座算法
                async executeDepartmentAlgorithm() {
                    console.log('执行按部门排座算法...');

                    // 1. 首先安排VIP
                    const vipAttendees = this.getVipAttendees();
                    await this.assignVipSeats(vipAttendees);

                    // 2. 按部门集中安排
                    const deptMap = this.getAttendeesByDepartment();
                    const availableSeats = this.getAllAvailableSeats();

                    let seatIndex = 0;
                    // 按部门人数排序，人数多的部门优先
                    const departments = Object.keys(deptMap).sort((a, b) =>
                        deptMap[b].length - deptMap[a].length
                    );

                    for (const dept of departments) {
                        const deptAttendees = deptMap[dept].filter(a => !a.isVip);
                        for (const attendee of deptAttendees) {
                            if (seatIndex < availableSeats.length) {
                                this.assignAttendeeToSeat(attendee, availableSeats[seatIndex]);
                                seatIndex++;
                            }
                        }
                    }

                    console.log('按部门排座算法执行完成');
                },

                // 按职级排座算法
                async executePositionAlgorithm() {
                    console.log('执行按职级排座算法...');

                    // 1. 首先安排VIP
                    const vipAttendees = this.getVipAttendees();
                    await this.assignVipSeats(vipAttendees);

                    // 2. 按职级排序：总监 > 经理 > 主管 > 专员
                    const positionOrder = { '总监': 1, '经理': 2, '主管': 3, '专员': 4 };
                    const remainingAttendees = this.attendees.filter(a => !a.isVip);
                    remainingAttendees.sort((a, b) => {
                        const orderA = positionOrder[a.position] || 999;
                        const orderB = positionOrder[b.position] || 999;
                        return orderA - orderB;
                    });

                    // 3. 从前到后按职级分配
                    const availableSeats = this.getAllAvailableSeats();
                    for (let i = 0; i < Math.min(remainingAttendees.length, availableSeats.length); i++) {
                        this.assignAttendeeToSeat(remainingAttendees[i], availableSeats[i]);
                    }

                    console.log('按职级排座算法执行完成');
                },

                // 随机排座算法
                async executeRandomAlgorithm() {
                    console.log('执行随机排座算法...');

                    // 1. 首先安排VIP（即使随机也要保证VIP位置）
                    const vipAttendees = this.getVipAttendees();
                    await this.assignVipSeats(vipAttendees);

                    // 2. 剩余人员完全随机分配
                    const remainingAttendees = this.attendees.filter(a => !a.isVip);
                    // Shuffle数组
                    for (let i = remainingAttendees.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [remainingAttendees[i], remainingAttendees[j]] = [remainingAttendees[j], remainingAttendees[i]];
                    }

                    const availableSeats = this.getAllAvailableSeats();
                    for (let i = 0; i < Math.min(remainingAttendees.length, availableSeats.length); i++) {
                        this.assignAttendeeToSeat(remainingAttendees[i], availableSeats[i]);
                    }

                    console.log('随机排座算法执行完成');
                },

                // ==================== 辅助排座方法 ====================
                // 为VIP分配座位（前排居中）- 使用技术方案的方法
                async assignVipSeats(vipAttendees) {
                    if (!vipAttendees || vipAttendees.length === 0) return;

                    console.log('为', vipAttendees.length, '名VIP分配座位');

                    // 使用技术方案中的 getFrontCenterSeats 方法
                    const vipSeats = this.getFrontCenterSeats(vipAttendees.length);

                    vipAttendees.forEach((attendee, index) => {
                        if (vipSeats[index]) {
                            this.assignAttendeeToSeat(attendee, vipSeats[index]);
                        }
                    });
                },

                // ==================== 技术方案：获取前排居中座位 ====================
                getFrontCenterSeats(count) {
                    const allSeats = this.getAllAvailableSeats();

                    return allSeats
                        .sort((a, b) => {
                            // 行优先（前排）
                            if (a.row !== b.row) return a.row - b.row;

                            // 同一行按居中程度排序
                            const rowSeats = this.getRowSeats(a.areaId, a.row);
                            const center = Math.floor(rowSeats.length / 2);
                            const distA = Math.abs(a.col - center);
                            const distB = Math.abs(b.col - center);
                            return distA - distB;
                        })
                        .slice(0, count);
                },

                // 为有特殊需求的人员分配座位
                async assignSpecialNeedsSeats(specialAttendees) {
                    if (!specialAttendees || specialAttendees.length === 0) return;

                    console.log('为', specialAttendees.length, '名有特殊需求的人员分配座位');

                    // 为轮椅用户安排通道旁的座位
                    const wheelchairAttendees = specialAttendees.filter(a => a.specialNeeds.includes('wheelchair'));
                    const otherSpecialAttendees = specialAttendees.filter(a => !a.specialNeeds.includes('wheelchair'));

                    const availableSeats = this.getAllAvailableSeats();

                    // 优先安排轮椅用户（选择每行靠边的座位）
                    const edgeSeats = availableSeats.filter(seat => {
                        const rowSeats = this.getRowSeats(seat.areaId, seat.row);
                        return seat.number === 1 || seat.number === rowSeats.length;
                    });

                    let seatIndex = 0;
                    for (const attendee of wheelchairAttendees) {
                        if (seatIndex < edgeSeats.length) {
                            this.assignAttendeeToSeat(attendee, edgeSeats[seatIndex]);
                            seatIndex++;
                        }
                    }

                    // 安排其他有特殊需求的人员
                    const remainingSeats = availableSeats.filter(seat =>
                        !edgeSeats.some(es => es.id === seat.id)
                    );

                    seatIndex = 0;
                    for (const attendee of otherSpecialAttendees) {
                        if (seatIndex < remainingSeats.length) {
                            this.assignAttendeeToSeat(attendee, remainingSeats[seatIndex]);
                            seatIndex++;
                        }
                    }
                },

                // 按部门安排人员（部门内部按职级排序）
                async assignByDepartmentWithPosition(attendees) {
                    if (!attendees || attendees.length === 0) return;

                    console.log('按部门安排', attendees.length, '名人员');

                    // 按部门分组
                    const deptMap = {};
                    attendees.forEach(att => {
                        if (!deptMap[att.department]) {
                            deptMap[att.department] = [];
                        }
                        deptMap[att.department].push(att);
                    });

                    // 部门内部按职级排序
                    const positionOrder = { '总监': 1, '经理': 2, '主管': 3, '专员': 4 };
                    Object.keys(deptMap).forEach(dept => {
                        deptMap[dept].sort((a, b) => {
                            const orderA = positionOrder[a.position] || 999;
                            const orderB = positionOrder[b.position] || 999;
                            return orderA - orderB;
                        });
                    });

                    // 获取可用座位
                    const availableSeats = this.getAllAvailableSeats();

                    // 按部门人数从多到少排序
                    const departments = Object.keys(deptMap).sort((a, b) =>
                        deptMap[b].length - deptMap[a].length
                    );

                    let seatIndex = 0;
                    for (const dept of departments) {
                        for (const attendee of deptMap[dept]) {
                            if (seatIndex < availableSeats.length) {
                                this.assignAttendeeToSeat(attendee, availableSeats[seatIndex]);
                                seatIndex++;
                            }
                        }
                    }
                },

                // 获取指定行的所有座位
                getRowSeats(areaId, rowNum) {
                    const area = this.seatingAreas.find(a => a.id === areaId);
                    if (!area) return [];

                    const row = area.rows.find(r => r.number === rowNum);
                    return row ? row.seats : [];
                },

                // 检测座位冲突
                detectConflicts() {
                    this.conflicts = [];

                    // 检查是否有重复分配
                    const assignedSeats = [];
                    this.seatingAreas?.forEach(area => {
                        area?.rows?.forEach(row => {
                            row?.seats?.forEach(seat => {
                                if (seat?.status === 'occupied' && seat?.occupant) {
                                    const existing = assignedSeats.find(s => s?.occupant?.id === seat.occupant.id);
                                    if (existing) {
                                        this.conflicts.push({
                                            id: `conflict_${seat.id}`,
                                            type: 'duplicate',
                                            attendee: seat.occupant.name,
                                            seats: [existing.id, seat.id],
                                            description: `${seat.occupant.name} 被分配到多个座位`
                                        });
                                    } else {
                                        assignedSeats.push(seat);
                                    }
                                }
                            });
                        });
                    });

                    if (this.conflicts.length > 0) {
                        console.warn('检测到', this.conflicts.length, '个座位冲突');
                    }
                },

                // 应用排座规则
                applySeatingRules() {
                    // VIP前排规则
                    if (this.rules.vipFrontRow) {
                        this.applyVipFrontRowRule();
                    }
                    // VIP居中规则
                    if (this.rules.vipCenter) {
                        this.applyVipCenterRule();
                    }
                    // 同部门优先相邻规则
                    if (this.rules.departmentTogether) {
                        this.applyDepartmentTogetherRule();
                    }
                    // 按职级分配区域规则
                    if (this.rules.positionOrder) {
                        this.applyPositionOrderRule();
                    }
                },

                // VIP前排规则
                applyVipFrontRowRule() {
                    // 将VIP座位安排在前排
                },

                // VIP居中规则
                applyVipCenterRule() {
                    // 将VIP座位安排在中间位置
                },

                // 同部门优先相邻规则
                applyDepartmentTogetherRule() {
                    // 同部门人员相邻安排
                },

                // 按职级分配区域规则
                applyPositionOrderRule() {
                    // 按职级高低分配区域
                },

                getAlgorithmName(algoId) {
                    const algo = this.algorithms.find(a => a.id === algoId);
                    return algo ? algo.name : algoId;
                },

                // 更新统计数据
                updateStatistics() {
                    let totalSeats = 0;
                    let assigned = 0;
                    let vip = 0;
                    const deptCount = {};

                    this.seatingAreas?.forEach(area => {
                        area?.rows?.forEach(row => {
                            row?.seats?.forEach(seat => {
                                totalSeats++;
                                if (seat?.status === 'occupied') {
                                    assigned++;
                                    if (seat?.type === 'vip') {
                                        vip++;
                                    }
                                    // 统计部门分布
                                    if (seat?.occupant?.department) {
                                        deptCount[seat.occupant.department] = (deptCount[seat.occupant.department] || 0) + 1;
                                    }
                                }
                            });
                        });
                    });

                    // 更新统计数据
                    this.statistics = {
                        totalSeats: totalSeats,
                        assigned: assigned,
                        vip: vip,
                        available: totalSeats - assigned,
                        completionRate: totalSeats > 0 ? Math.round((assigned / totalSeats) * 100) : 0
                    };

                    // 更新部门分布
                    this.departmentDistribution = Object.keys(deptCount).map(dept => ({
                        name: dept,
                        count: deptCount[dept]
                    }));
                },

                // 模拟填充座位
                simulateSeating() {
                    let assigned = 0;
                    const targetAssigned = Math.floor(this.statistics.totalSeats * 0.7);
                    let vipCount = 0;

                    this.seatingAreas?.forEach(area => {
                        area?.rows?.forEach(row => {
                            row?.seats?.forEach(seat => {
                                if (assigned >= targetAssigned) return;

                                // VIP区域优先分配VIP座位
                                if (area?.id === 'area_a' && vipCount < 45) {
                                    seat.type = 'vip';
                                    seat.status = 'occupied';
                                    seat.occupant = {
                                        name: `VIP学员${vipCount + 1}`,
                                        department: '管理部门'
                                    };
                                    vipCount++;
                                    assigned++;
                                } else if (area?.id !== 'area_a') {
                                    seat.status = 'occupied';
                                    seat.occupant = {
                                        name: `学员${assigned}`,
                                        department: ['技术部', '产品部', '市场部', '销售部'][assigned % 4]
                                    };
                                    assigned++;
                                }
                            });
                        });
                    });

                    this.updateStatistics();
                },
                
                async clearSeating() {
                    const confirmed = await this.$showConfirm(
                        '确定要清空所有座位分配吗？',
                        '清空座位',
                        'warning'
                    );
                    if (confirmed) {
                        this.seatingAreas?.forEach(area => {
                            area?.rows?.forEach(row => {
                                row?.seats?.forEach(seat => {
                                    seat.status = 'available';
                                    seat.occupant = null;
                                });
                            });
                        });
                        this.statistics.assigned = 0;
                        this.statistics.available = this.statistics.totalSeats;
                        this.$showToast('座位已清空', 'success');

                        // 保存到历史记录
                        this.saveToHistory('clearSeating');
                    }
                },
                
