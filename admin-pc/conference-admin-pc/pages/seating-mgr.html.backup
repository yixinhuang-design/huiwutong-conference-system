                        area?.rows?.forEach(row => {
                            row?.seats?.forEach(seat => {
                                if (seat?.status === 'available') {
                                    // 模拟按规则排座
                                    // 实际应该从报名人员数据中获取
                                }
                            });
                        });
                    });
                    this.$showToast(`按${this.getRuleText(rule)}排座完成`, 'success');
                },

                // 按分区排座
                async executeZoneSeating() {
                    await new Promise(resolve => setTimeout(resolve, 1500));
                    // 模拟按分区排座
                    this.$showToast(`按${this.zoneConfig.count}个分区排座完成`, 'success');
                },

                getRuleText(rule) {
                    const map = {
                        'department': '部门',
                        'position': '职级',
                        'roster': '名册顺序'
                    };
                    return map[rule] || rule;
                },

                // 辅助安排相关方法
                assignVehicle(vehicleId) {
