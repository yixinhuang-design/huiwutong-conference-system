                // ==================== 座位区配置相关方法 ====================
                // 打开添加座位区弹窗
                openAddAreaModal() {
                    console.log('[打开弹窗] 准备打开添加座位区弹窗');
                    this.editingArea = null;
                    this.resetAreaConfig();
                    this.showAreaConfigModal = true;
                    console.log('[打开弹窗] showAreaConfigModal已设置为true');
                },

                // 打开编辑座位区弹窗
                editArea(areaId) {
                    const area = this.seatingAreas.find(a => a.id === areaId);
                    if (!area) {
                        this.$showToast('未找到该座位区', 'error');
                        return;
                    }

                    this.editingArea = area;

                    // 加载区域配置
                    this.areaConfig = {
                        name: area.name,
                        type: area.type,
                        rows: area.rows.length,
                        cols: area.rows[0]?.seats.length || 10,
                        angle: 0,
                        hasAisle: false,
                        aislePosition: 'center',
                        aisleWidth: 1,
                        hasFixedSeats: false,
                        fixedSeatsPattern: ''
                    };

                    this.showAreaConfigModal = true;
                },

                // 关闭配置弹窗
                closeAreaConfig() {
                    console.log('[关闭弹窗] ========== 开始关闭流程 ==========');
                    console.log('[关闭弹窗] 关闭前 showAreaConfigModal:', this.showAreaConfigModal);

                    this.showAreaConfigModal = false;
                    this.editingArea = null;

                    console.log('[关闭弹窗] 设置后 showAreaConfigModal:', this.showAreaConfigModal);

                    // 使用 nextTick 确保 DOM 更新
                    this.$nextTick(() => {
                        console.log('[关闭弹窗] nextTick 后 showAreaConfigModal:', this.showAreaConfigModal);
                        const modal = document.querySelector('.area-config-modal');
                        if (modal) {
                            console.log('[关闭弹窗] ⚠️  弹窗仍然存在于 DOM 中，强制移除');
                            modal.style.display = 'none';
                        } else {
                            console.log('[关闭弹窗] ✅ 弹窗已从 DOM 中移除');
                        }
                    });

                    this.resetAreaConfig();
                    console.log('[关闭弹窗] ========== 关闭流程完成 ==========');
                },

                // 重置配置
                resetAreaConfig() {
                    this.areaConfig = {
                        name: '',
                        type: 'regular',
                        rows: 10,
                        cols: 15,
                        angle: 0,
                        hasAisle: false,
                        aislePosition: 'center',
                        aisleWidth: 1,
                        hasFixedSeats: false,
                        fixedSeatsPattern: ''
                    };
                },

                // 调整行数
                adjustRows(delta) {
                    const newValue = this.areaConfig.rows + delta;
                    if (newValue >= 1 && newValue <= 20) {
                        this.areaConfig.rows = newValue;
                    }
                },

                // 调整列数
                adjustCols(delta) {
                    const newValue = this.areaConfig.cols + delta;
                    if (newValue >= 1 && newValue <= 30) {
                        this.areaConfig.cols = newValue;
                    }
                },

                // 保存座位区配置
                async saveAreaConfig() {
                    // 验证
                    if (!this.areaConfig.name || !this.areaConfig.name.trim()) {
                        this.$showToast('请输入区域名称', 'warning');
                        return;
                    }

                    try {
                        this.$showLoading(this.editingArea ? '正在保存...' : '正在创建...');

                        // 生成座位区
                        const areaData = this.generateAreaFromConfig(this.areaConfig);

                        if (this.editingArea) {
                            // 编辑模式：更新现有区域
                            const index = this.seatingAreas.findIndex(a => a.id === this.editingArea.id);
                            if (index !== -1) {
                                this.seatingAreas[index] = areaData;
                            }
                        } else {
                            // 新增模式：添加新区域
                            this.seatingAreas.push(areaData);
                        }

                        this.$hideLoading();
                        this.$showToast(this.editingArea ? '座位区已更新' : '座位区已创建', 'success');

                        this.closeAreaConfig();
                        this.updateStatistics();

                        // 保存到历史记录
                        this.saveToHistory(this.editingArea ? 'editArea' : 'addArea');

                    } catch (error) {
                        this.$hideLoading();
                        this.$showToast('保存失败: ' + error.message, 'error');
                    }
                },

                // 根据配置生成座位区
                generateAreaFromConfig(config) {
                    const areaId = this.editingArea ? this.editingArea.id : `area_${Date.now()}`;
                    const areaName = config.name.trim();
                    const areaType = config.type;

                    // 使用 generateSeatingLayout 生成座位
                    const rows = this.generateSeatingLayout({
                        areaId: areaId.replace('area_', ''),
                        rows: config.rows,
                        cols: config.cols,
                        angle: config.angle,
                        type: areaType
                    });

                    // 处理过道
                    if (config.hasAisle) {
                        this.applyAisleToRows(rows, config);
                    }

                    // 处理固定座位
                    if (config.hasFixedSeats && config.fixedSeatsPattern) {
                        this.applyFixedSeatsToRows(rows, config.fixedSeatsPattern);
                    }

                    return {
                        id: areaId,
                        name: areaName,
                        type: areaType,
                        angle: config.angle || 0,
                        hasAisle: config.hasAisle || false,
                        aislePosition: config.aislePosition || 'center',
                        aisleWidth: config.aisleWidth || 1,
                        hasFixedSeats: config.hasFixedSeats || false,
                        rows: rows
                    };
                },

                // 应用过道
                applyAisleToRows(rows, config) {
                    const aisleCol = this.getAisleColumn(config);

                    rows.forEach(row => {
                        // 标记该行是否包含过道
                        const hasAisleInRow = row.seats.some(seat =>
                            this.isSeatInAisle(seat, aisleCol, config)
                        );
                        row.hasAisle = hasAisleInRow;

                        row.seats.forEach(seat => {
                            if (this.isSeatInAisle(seat, aisleCol, config)) {
                                seat.isAisle = true;
                                seat.status = 'aisle';
                                seat.type = 'aisle';
                            }
                        });
                    });
                },

                // 获取过道列号
                getAisleColumn(config) {
                    const totalCols = config.cols;
                    const aisleWidth = config.aisleWidth;

                    switch (config.aislePosition) {
                        case 'left':
                            return Array.from({ length: aisleWidth }, (_, i) => i + 1);
                        case 'right':
                            return Array.from({ length: aisleWidth }, (_, i) => totalCols - i);
                        case 'center':
                            const center = Math.ceil(totalCols / 2);
                            return Array.from({ length: aisleWidth }, (_, i) => center - Math.floor(aisleWidth / 2) + i);
                        default:
                            return [];
                    }
                },

                // 判断座位是否在过道
                isSeatInAisle(seat, aisleCols, config) {
                    return aisleCols.includes(seat.col);
                },

                // 应用固定座位
                applyFixedSeatsToRows(rows, pattern) {
                    const fixedSeats = this.parseFixedSeatsPattern(pattern);

                    rows.forEach(row => {
                        row.seats.forEach(seat => {
                            if (fixedSeats.some(fs => fs.row === row.number && fs.col === seat.col)) {
                                seat.isFixed = true;
                                seat.type = 'fixed';
                            }
                        });
                    });
                },

                // 解析固定座位模式
                parseFixedSeatsPattern(pattern) {
                    const fixed = [];

                    // 格式1: "1排1号, 1排2号, 2排5号"
                    const parts = pattern.split(',').map(p => p.trim());
                    parts.forEach(part => {
                        if (part.includes('排')) {
                            const [rowPart, colPart] = part.split('排');
                            const row = parseInt(rowPart);
                            const colPartEnd = colPart.replace('号', '');
                            if (colPartEnd.includes('-')) {
                                // 范围：1-5
                                const [start, end] = colPartEnd.split('-').map(n => parseInt(n));
                                for (let c = start; c <= end; c++) {
                                    fixed.push({ row, col: c });
                                }
                            } else {
                                const col = parseInt(colPartEnd);
                                fixed.push({ row, col });
                            }
                        }
                    });

                    return fixed;
                },

                // 判断座位是否为固定座位（用于预览）
                isSeatFixed(row, col, pattern) {
                    if (!pattern || !pattern.trim()) return false;

                    const fixedSeats = this.parseFixedSeatsPattern(pattern);
                    return fixedSeats.some(fs => fs.row === row && fs.col === col);
                },

                async deleteArea(areaId) {
                    const confirmed = await this.$showConfirm(
                        '确定要删除该座位区吗？',
                        '删除座位区',
                        'warning'
                    );
                    if (confirmed) {
                        this.seatingAreas = this.seatingAreas.filter(a => a.id !== areaId);
                        this.$showToast('座位区已删除', 'success');
                    }
                },

                // 排座方式相关方法
                handleExcelUpload(event) {
