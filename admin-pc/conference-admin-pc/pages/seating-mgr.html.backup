                        this.$showLoading('正在智能分配讨论室...');
                        await new Promise(resolve => setTimeout(resolve, 1500));
                        this.$hideLoading();
                        this.$showToast('讨论室智能分配完成', 'success');
                    } catch (error) {
                        this.$hideLoading();
                        this.$showToast('分配失败', 'error');
                    }
                },

                async sendArrangementNotifications() {
                    const confirmed = await this.$showConfirm(
                        '确定要发送辅助安排通知吗？包含座位、车号、住宿、讨论等信息',
                        '发送通知',
                        'info'
                    );
                    if (confirmed) {
                        try {
                            this.$showLoading('正在发送通知...');
                            await new Promise(resolve => setTimeout(resolve, 2000));
                            this.$hideLoading();
                            this.$showToast('辅助安排通知已发送', 'success');
                        } catch (error) {
